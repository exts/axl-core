{
  "name": "exts/axl-core",
  "description": "PHP AI Platform Bridge",
  "type": "library",
  "license": "MIT",
  "version": "1.0.0-dev",
  "keywords": [
    "ai bridge",
    "ai platform bridge",
    "exts ai",
    "exts axl",
    "exts axl core",
    "exts axl core ai",
    "exts axl core ai bridge"
  ],
  "authors": [
    {
      "name": "Lamonte Harris"
    }
  ],
  "require": {
    "php": ">=8.3",
    "guzzlehttp/guzzle": "^7.0",
    "php-di/php-di": "^7.1",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.1",
    "psr/http-message": "^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0",
    "symfony/dotenv": "v7.4.0"
  },
  "autoload": {
    "psr-4": {
      "AxlCore\\": "Source/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AxlCore\\Tests\\": "Tests/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "scripts": {
    "demo": "php Example/axl-demo.php",
    "demo2": "php Example/axl-image-demo.php",
    "demo3": "php Example/axl-anthropic-demo.php",
    "demo4": "php Example/axl-stream-demo.php",
    "demo5": "php Example/axl-nano-banana-demo.php",
    "test": "phpunit"
  }
}
